#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

# Run quick checks before commit
echo "Running pre-commit checks..."

# Check for debug statements
if grep -r "console\.log\|debugger\|TODO\|FIXME" --include="*.ts" --include="*.tsx" src/ 2>/dev/null | grep -v ".test." | grep -v "node_modules" | grep -v ".husky"; then
  echo "⚠️  Warning: Found console.log/debugger/TODO/FIXME in source files"
  echo "Consider cleaning these up before committing"
fi

# Run quick type check (optional, can be slow)
# npx tsc --noEmit --skipLibCheck 2>&1 | head -20