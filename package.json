{
  "name": "stria-systems-website",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "vite build",
    "deploy:cloudflare": "npm run build && wrangler pages deploy dist --project-name stria-systems --branch main",
    "preview": "vite preview --host 0.0.0.0",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint:commits": "commitlint --from=HEAD~1 --to=HEAD",
    "commit": "git-cz",
    "prepare": "husky install",
    "trace:typecheck": "cd trace-core/ts-wrapper && npm run build",
    "context:sync": "node sync-context.cjs",
    "audit:edge-cases": "node edge-case-audit.cjs",
    "audit:visual": "npx playwright test",
    "smoke:local": "BASE_URL=http://localhost:5176 node smoke-tests.cjs",
    "smoke:prod": "BASE_URL=https://striasystems.com node smoke-tests.cjs",
    "deploy:monitor": "node deploy-monitor.cjs",
    "monitor:comprehensive": "node monitor-comprehensive.cjs"
  },
  "dependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@react-three/postprocessing": "^3.0.4",
    "@trace/core": "file:./trace-core",
    "lucide-react": "^1.21.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.0",
    "three": "^0.184.0",
    "three-stdlib": "^2.36.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@commitlint/cli": "^19.5.0",
    "@commitlint/config-conventional": "^19.5.0",
    "@commitlint/prompt-cli": "^19.5.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.0",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^11.0.1",
    "@semantic-release/npm": "^12.0.1",
    "@semantic-release/release-notes-generator": "^14.0.1",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.4",
    "ajv-formats": "^3.0.1",
    "axe-core": "^4.12.1",
    "chrome-launcher": "^1.2.1",
    "husky": "^9.1.6",
    "lighthouse": "^13.4.0",
    "playwright": "^1.60.0",
    "puppeteer": "^25.1.0",
    "rollup-plugin-visualizer": "^7.0.1",
    "semantic-release": "^24.2.0",
    "typescript": "^5.6.3",
    "vite": "^6.0.7",
    "vitest": "^4.1.8",
    "wrangler": "^4.98.0"
  },
  "description": "The official Stria Systems website — built with React, Vite, and deployed to Cloudflare Pages.",
  "main": "index.js",
  "directories": {
    "doc": "docs",
    "example": "examples",
    "test": "tests"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Camnaz/StriaSystems.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/Camnaz/StriaSystems/issues"
  },
  "homepage": "https://github.com/Camnaz/StriaSystems#readme"
}
