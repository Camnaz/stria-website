{
  "name": "stria-systems-website",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "vite build",
    "deploy:cloudflare": "npm run build && wrangler pages deploy dist --project-name stria-systems --branch main",
    "preview": "vite preview --host 0.0.0.0",
    "test": "vitest run",
    "lint:commits": "commitlint --from=HEAD~1 --to=HEAD",
    "commit": "git-cz",
    "prepare": "husky install"
  },
  "dependencies": {
    "@trace/core": "^0.1.0",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.17.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@commitlint/prompt-cli": "^21.0.2",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.0",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.8",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.0.1",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "husky": "^9.1.6",
    "rollup-plugin-visualizer": "^7.0.1",
    "semantic-release": "^25.0.5",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8",
    "wrangler": "^4.98.0"
  },
  "description": "The official Stria Systems website — built with React, Vite, and deployed to Cloudflare Pages.",
  "main": "index.js",
  "directories": {
    "doc": "docs",
    "example": "examples",
    "test": "tests"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Camnaz/StriaSystems.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/Camnaz/StriaSystems/issues"
  },
  "homepage": "https://github.com/Camnaz/StriaSystems#readme"
}
