{
  "name": "stria-systems-website",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "vite build",
    "deploy:cloudflare": "npm run build && wrangler pages deploy dist --project-name stria-systems --branch main",
    "preview": "vite preview --host 0.0.0.0",
    "test": "vitest run",
    "lint:commits": "commitlint --from=HEAD~1 --to=HEAD",
    "commit": "git-cz",
    "prepare": "husky install",
    "trace:typecheck": "cd trace-core/ts-wrapper && npm run build"
  },
  "dependencies": {
    "@trace/core": "^0.1.0",
    "gsap": "^3.15.0",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.17.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.5.0",
    "@commitlint/config-conventional": "^19.5.0",
    "@commitlint/prompt-cli": "^19.5.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.0",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^11.0.1",
    "@semantic-release/npm": "^12.0.1",
    "@semantic-release/release-notes-generator": "^14.0.1",
    "@types/node": "^25.9.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "husky": "^9.1.6",
    "rollup-plugin-visualizer": "^7.0.1",
    "semantic-release": "^24.2.0",
    "typescript": "^5.6.3",
    "vite": "^6.0.7",
    "vitest": "^4.1.8",
    "wrangler": "^4.98.0",
    "ajv-formats": "^3.0.1"
  },
  "description": "The official Stria Systems website — built with React, Vite, and deployed to Cloudflare Pages.",
  "main": "index.js",
  "directories": {
    "doc": "docs",
    "example": "examples",
    "test": "tests"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Camnaz/StriaSystems.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/Camnaz/StriaSystems/issues"
  },
  "homepage": "https://github.com/Camnaz/StriaSystems#readme"
}
