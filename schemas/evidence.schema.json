{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://striasystems.com/schemas/evidence.schema.json",
  "title": "Trace Evidence Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_id",
    "organization_id",
    "environment",
    "agent_id",
    "agent_identity_version",
    "human_owner_operator",
    "action_allowed",
    "ingress_envelope",
    "action_payload",
    "evaluation_ledger",
    "chain_of_custody"
  ],
  "properties": {
    "record_id": {
      "type": "string",
      "pattern": "^ev_[a-z0-9_:-]+$"
    },
    "organization_id": {
      "type": "string",
      "minLength": 1
    },
    "environment": {
      "type": "string",
      "enum": ["development", "staging", "production"]
    },
    "agent_id": {
      "type": "string",
      "minLength": 1
    },
    "agent_identity_version": {
      "type": "string",
      "minLength": 1
    },
    "human_owner_operator": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "email", "team"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "email": { "type": "string", "format": "email" },
        "team": { "type": "string", "minLength": 1 }
      }
    },
    "action_allowed": {
      "type": "boolean"
    },
    "standardized_error": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "required": ["code", "message", "rule_id"],
      "properties": {
        "code": { "type": "string", "minLength": 1 },
        "message": { "type": "string", "minLength": 1 },
        "rule_id": { "type": "string", "minLength": 1 }
      }
    },
    "ingress_envelope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "prompt_hash",
        "model_provider",
        "model_name",
        "model_config_hash",
        "parent_context_hash"
      ],
      "properties": {
        "prompt_hash": { "$ref": "#/$defs/sha256" },
        "model_provider": { "type": "string", "minLength": 1 },
        "model_name": { "type": "string", "minLength": 1 },
        "model_config_hash": { "$ref": "#/$defs/sha256" },
        "parent_context_hash": { "$ref": "#/$defs/sha256" }
      }
    },
    "action_payload": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tool_name",
        "tool_namespace",
        "arguments_hash",
        "redacted_arguments_preview",
        "resources_targeted",
        "resources_modified"
      ],
      "properties": {
        "tool_name": { "type": "string", "minLength": 1 },
        "tool_namespace": { "type": "string", "minLength": 1 },
        "arguments_hash": { "$ref": "#/$defs/sha256" },
        "redacted_arguments_preview": {
          "type": "object",
          "additionalProperties": true
        },
        "resources_targeted": {
          "type": "array",
          "items": { "type": "string" }
        },
        "resources_modified": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "evaluation_ledger": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "policy_id",
          "policy_version",
          "rule_id",
          "rule_mode",
          "result",
          "reason",
          "severity"
        ],
        "properties": {
          "policy_id": { "type": "string", "minLength": 1 },
          "policy_version": { "type": "string", "minLength": 1 },
          "rule_id": { "type": "string", "minLength": 1 },
          "rule_mode": { "type": "string", "enum": ["observe", "enforce"] },
          "result": { "type": "string", "enum": ["pass", "flag", "block"] },
          "reason": { "type": "string", "minLength": 1 },
          "severity": {
            "type": "string",
            "enum": ["info", "low", "medium", "high", "critical"]
          }
        }
      }
    },
    "chain_of_custody": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "received_timestamp",
        "evaluated_timestamp",
        "emitted_timestamp",
        "processing_node_id",
        "previous_record_hash",
        "record_hash",
        "signature_stub"
      ],
      "properties": {
        "received_timestamp": { "type": "string", "format": "date-time" },
        "evaluated_timestamp": { "type": "string", "format": "date-time" },
        "emitted_timestamp": { "type": "string", "format": "date-time" },
        "processing_node_id": { "type": "string", "minLength": 1 },
        "previous_record_hash": {
          "anyOf": [{ "$ref": "#/$defs/sha256" }, { "type": "null" }]
        },
        "record_hash": { "$ref": "#/$defs/sha256" },
        "signature_stub": { "type": "string", "minLength": 1 }
      }
    }
  },
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    }
  }
}
